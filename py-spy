# by fastapi
import time
import logging

def install_request_timing(app, name):
    @app.middleware("http")
    async def log_request_time(request: Request, call_next):
        start = time.perf_counter()
        start_cpu = time.process_time()

        try:
            response = await call_next(request)
            return response
        finally:
            wall_ms = (time.perf_counter() - start) * 1000
            cpu_ms = (time.process_time() - start_cpu) * 1000

            if wall_ms > 500 or cpu_ms > 200:
                logging.warning(
                    "slow_request app=%s method=%s path=%s wall_ms=%.1f cpu_ms=%.1f",
                    name,
                    request.method,
                    request.url.path,
                    wall_ms,
                    cpu_ms,
                )

install_request_timing(app, "api")
install_request_timing(app_mqtt_systems, "mqtt")

tail -f app.log | grep slow_request

