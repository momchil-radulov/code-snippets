#!/usr/bin/env bash
set -euo pipefail

# === Конфигурация ===
HOST_ALIAS="server_db"                # ssh alias (от ~/.ssh/config)
DB_NAME="iotdb"
LOCAL_DIR="$HOME/backups/postgresql"  # къде да пазим архивите локално
RETAIN_DAYS=30                        # колко дни да пазим
SUDO_CMD="sudo -n"                    # ако имаш sudo права

# Създай локалната папка, ако липсва
mkdir -p "$LOCAL_DIR"

# Име на файла: admin_muhtarov_YYYY-MM-DD.sql.gz
STAMP="$(date +%F)"
OUTFILE="${LOCAL_DIR}/${DB_NAME}_${STAMP}.sql.gz"

# Проверки
command -v ssh >/dev/null
command -v gzip >/dev/null

echo "[*] Правя дамп на ${DB_NAME} от ${HOST_ALIAS} → ${OUTFILE}"

# ВНИМАНИЕ: ако sudo иска парола, виж бележките долу за NOPASSWD или SUDO_CMD=""
# Стрийм през SSH, без временен файл на сървъра:
ssh -o RequestTTY=no "${HOST_ALIAS}" \
  "${SUDO_CMD} -u postgres pg_dump --no-owner --no-privileges --column-inserts --format=plain ${DB_NAME} | gzip -c" \
  > "${OUTFILE}"

# Верификация (по желание)
gzip -t "${OUTFILE}"
echo "[✓] Готово: ${OUTFILE}"

# Ротация на стари архиви
if [[ "${RETAIN_DAYS}" -gt 0 ]]; then
  find "${LOCAL_DIR}" -type f -name "${DB_NAME}_*.sql.gz" -mtime +${RETAIN_DAYS} -print -delete || true
fi

exit

# как да възстановим
-- 1) спираш нови връзки
REVOKE CONNECT ON DATABASE iotdb FROM PUBLIC;
REVOKE CONNECT ON DATABASE iotdb FROM iotuser;

-- 2) прекъсваш активните връзки
SELECT pg_terminate_backend(pid)
FROM pg_stat_activity
WHERE datname = 'iotdb'
  AND pid <> pg_backend_pid();

-- 3) триеш старата база
DROP DATABASE iotdb;

-- 4) създаваш празна нова база със същия owner
CREATE DATABASE iotdb
  OWNER iotuser
  ENCODING 'UTF8'
  LC_COLLATE 'en_US.UTF-8'
  LC_CTYPE 'en_US.UTF-8'
  TEMPLATE template0;

-- 5) излизаш
\q

# cli
gunzip -c /home/momchil/backups/pgsql/iotdb_2026-06-30.sql.gz | sudo -u postgres psql -d iotdb
OR
gunzip -c /home/momchil/backups/kemsa/iotdb_2026-06-30.sql.gz > /tmp/iotdb.dump
sudo -u postgres pg_restore -d iotdb /tmp/iotdb.dump

# test
sudo -u postgres psql -d iotdb -c "\dt"
sudo -u postgres psql -d iotdb -c "SELECT current_database(), current_user;"

