    # allow API without login
    Require expr %{REQUEST_URI} =~ m#^/api#

    # allow webhook
    Require expr %{REQUEST_URI} =~ m#^/webhook#

    # allow health check
    Require expr %{REQUEST_URI} =~ m#^/health#

    # otherwise require login
    Require valid-user

</RequireAny>
