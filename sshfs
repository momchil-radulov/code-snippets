# mount
sshfs user@server:/remote/path /local/path
sshfs -o reconnect user@server:/path ~/remote
sshfs -o cache=yes user@server:/path ~/remote
# list
findmnt -t fuse.sshfs
mount | grep sshfs
df -h
# umount
umount ~/remote_site
fusermount -u ~/remote_site
fusermount -uz ~/remote_site  # lazy unmount

[~/.bashrc]
alias mountyour_domain='sshfs -p 2222 \
-o reconnect,ServerAliveInterval=15,ServerAliveCountMax=3,compression=yes \
your_user@your_domain.com:/home/your_path \
~/remote/your_path'

alias umountyour_domain='fusermount -uz ~/remote/your_domain'
