###############################################################################
# USEFULL
###############################################################################

# Намери всички PHP файлове
find . -type f -name "*.php"

# Намери всички Python файлове
find . -type f -name "*.py"

# Намери файлове по-големи от 100 MB
find . -type f -size +100M

# Намери празни файлове
find . -type f -empty

# Намери празни директории
find . -type d -empty

# Намери символни връзки
find . -type l

# Намери файлове променяни последните 24 часа
find . -mtime -1

# Намери файлове по-стари от 30 дни
find . -mtime +30

# Намери файлове и ги изтрий
find . -name "*.tmp" -delete

# Намери файлове и изпълни команда върху тях
find . -name "*.log" -exec gzip {} \;

# Намери файлове без значение на малки/главни букви
find . -iname "*.jpg"

# Намери файлове, съдържащи "cache" в името
find . -name "*cache*"

# Намери всички директории "node_modules"
find . -type d -name node_modules

# Намери всички Git директории
find . -type d -name .git

# Намери файлове без да влиза в .git
find . -path ./.git -prune -o -name "*.php" -print


###############################################################################
# USEFULL PARAMS
###############################################################################

# Име
-name "*.php"
-iname "*.jpg"

# Тип
-type f      # файл
-type d      # директория
-type l      # symlink

# Размер
-size +100M
-size -1k

# Време
-mtime -1    # последните 24 часа
-mtime +30   # по-стари от 30 дни

# Собственик
-user ubuntu
-group www-data

# Действие
-print
-delete
-exec COMMAND {} \;

# Логически оператори
-not
-o            # OR
-a            # AND (по подразбиране)

# Прескачане на директория
-path "./.git" -prune -o ...

# Безопасно към xargs
-print0 | xargs -0
