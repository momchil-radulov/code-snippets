###############################################################################
# Python
###############################################################################

# Намери всички Python файлове и ги форматирай с black
find . | grep 'py$' | xargs black
find . -type f -name "*.py" | xargs black
# това работи коректно дори ако имената на файловете съдържат интервали, кавички или други специални символи
find . -type f -name "*.py" -print0 | xargs -0 pylint

# Намери всички .py файлове, но пропусни .git, venv и __pycache__
find . \
    \( -path "./.git" -o -path "./venv" -o -path "./__pycache__" \) -prune \
    -o \
    -type f -name "*.py" -print

# Намери всички Python файлове и ги провери с pylint
find . | grep 'py$' | xargs pylint

# Същото, но подава всеки файл поотделно към pylint
find . | grep 'py$' | xargs -I% pylint %

# Преглед на резултата през less
find . | grep 'py$' | xargs pylint | less


###############################################################################
# Django
###############################################################################

# Изтрий всички migration файлове (без __init__.py)
find . -path "*/migrations/*.py" \
    -not -name "__init__.py" \
    -delete

# Изтрий компилираните migration файлове
find . -path "*/migrations/*.pyc" \
    -delete


###############################################################################
# Backup
###############################################################################

# Изтрий backup-и по-стари от определен брой дни
find "${LOCAL_DIR}" \
    -type f \
    -name "${DB_NAME}_*.sql.gz" \
    -mtime +${RETAIN_DAYS} \
    -print \
    -delete


###############################################################################
# Ubuntu / Linux
###############################################################################

# Покажи 20-те най-големи файла в системата
sudo find / \
    -type f \
    -exec du -h {} + \
| sort -rh \
| head -n 20

# Изтрий crash dump файловете
sudo find /var/crash \
    -type f \
    -delete


