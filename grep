# network
# ngrep
sudo apt install ngrep
sudo ngrep -d lo -W byline '' 'tcp port 8000'
# tshark
sudo tshark -i lo -f "tcp port 8000" -w dump.pcap
tshark -r dump.pcap -T fields -e tcp.stream | sort -nu  # виж колко стрима има
tshark -r dump.pcap -qz follow,tcp,ascii,15 | less      # виж stream 15

# files

grep -rl 'http://' . | xargs sed -i 's|http://|https://|g'  # заместваме htpp със https

grep -Fxv -f file2.txt file1.txt
  -F → търси точни стрингове (не regex)
  -x → съвпадение на целия ред
  -v → обръща (взима НЕсъвпадащите)
  -f file2.txt → използва file2 като списък за сравнение
  👉 Резултат: редовете от file1.txt, които ги няма в file2.txt

