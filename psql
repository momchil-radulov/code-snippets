PGPASSWORD="mypassword" pg_dump -h localhost -U myuser -d mydb > mydb.sql
-- изчистване на базата, преди restore
-- ако има активни връзки → kill
SELECT pg_terminate_backend(pid)
FROM pg_stat_activity
WHERE datname = 'iotdb'
  AND pid <> pg_backend_pid();
DROP DATABASE iotdb;
CREATE DATABASE iotdb OWNER iotuser;
-- restore
sudo -u postgres pg_restore -U iotuser -d iotdb iotdb.dump

